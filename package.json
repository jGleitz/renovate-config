{
  "name": "renovate-config",
  "version": "1.0.0",
  "description": "Renovate configuration for Joshua Gleitze’s open source projects.",
  "main": "default.json5",
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "format": "prettier --write .",
    "lint": "prettier --check .",
