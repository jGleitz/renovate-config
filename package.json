{
  "name": "renovate-config",
  "version": "1.0.0",
  "description": "Renovate configuration for Joshua Gleitze’s open source projects.",
  "main": "default.json5",
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "validate": "renovate-config-validator --strict default.json5 renovate.json5",
    "test": "vitest run",
    "test:verbose": "vitest run --silent false",
    "check": "npm-run-all --parallel lint validate compile --sequential test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jGleitz/renovate-config.git"
  },
  "author": "Joshua Gleitze",
  "license": "MIT",
  "devDependencies": {
    "@types/which": "3.0.4",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.4",
    "renovate": "43.227.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "which": "6.0.1"
  },
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d"
}
