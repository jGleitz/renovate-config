{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices"],
  rebaseWhen: "behind-base-branch",
  automergeType: "branch",
  rangeStrategy: "pin",
  lockFileMaintenance: {
    enabled: true,
  },
  packageRules: [
    {
      // the engine requirement should match what is tested in CI. It shouldn’t be updated automatically.
      matchDepTypes: ["engines"],
      enabled: false,
    },
    {
      // peerDependencies should *not* be pinned. They are ranges to allow the widest possible compatibility.
      matchDepTypes: ["peerDependencies"],
      rangeStrategy: "widen",
    },
    {
      matchUpdateTypes: ["minor", "patch", "pin", "digest", "lockFileMaintenance"],
      automerge: true,
    },
    {
      matchPackageNames: ["renovatebot/renovate"],
      matchUpdateTypes: ["minor", "patch"],
      schedule: ["* 4-10 * * 5"],
    },
  ],
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["**/.sdkmanrc"],
      matchStrings: ["java\\s*=\\s*(?<currentValue>[\\d.]+)"],
      extractVersionTemplate: "^(?<version>[^+]+)",
      datasourceTemplate: "java-version",
      depNameTemplate: "java",
    },
  ],
}
